  <!-- badge -->
  <text x="80" y="120" font-family="Inter, Helvetica, sans-serif" font-size="14" font-weight="700" fill="#06b6d4" letter-spacing="2" opacity="0.95">RWA · TOKENIZED TREASURIES</text>

  <!-- title -->
  <text x="80" y="240" font-family="Inter, Helvetica, sans-serif" font-size="62" font-weight="800" fill="#ffffff">Tokenized Treasuries 2026</text>

  <!-- subtitle line 1 -->
  <text x="80" y="310" font-family="Inter, Helvetica, sans-serif" font-size="28" font-weight="600" fill="#cbd5e1">BlackRock BUIDL, Ondo OUSG, Franklin BENJI &#x2014;</text>

