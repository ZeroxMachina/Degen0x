  <text x="80" y="490" font-family="Inter, Helvetica, sans-serif" font-size="15" fill="#64748b">A complete guide to the tokenized US Treasury market &#x2014; products, yields, and rails.</text>

  <!-- degen0x branding -->
  <text x="1120" y="600" font-family="Inter, Helvetica, sans-serif" font-size="14" font-weight="600" fill="#6366f1" text-anchor="end" opacity="0.85">degen0x.com</text>

  <!-- bottom gradient line -->
  <rect y="622" width="1200" height="8" fill="url(#gradAccentTreas)" opacity="0.5"/>
</svg>
