    <text x="1100" y="510" font-family="Inter, Helvetica, sans-serif" font-size="58" font-weight="700" fill="url(#goldFillTreas)" opacity="0.55">$</text>
  </g>

  <!-- yield ladder bars (left of motif, suggesting tiered yields across products) -->
  <g opacity="0.55">
    <rect x="850" y="280" width="6" height="28" fill="#0891b2"/>
    <rect x="862" y="272" width="6" height="36" fill="#1e3a8a"/>
    <rect x="874" y="262" width="6" height="46" fill="#0891b2"/>
    <rect x="886" y="252" width="6" height="56" fill="#d4a017"/>
    <rect x="898" y="240" width="6" height="68" fill="#d4a017"/>
