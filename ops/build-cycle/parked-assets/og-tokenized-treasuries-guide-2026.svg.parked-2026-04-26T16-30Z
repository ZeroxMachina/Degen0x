    <line x1="982" y1="386" x2="1016" y2="386" stroke="#0891b2" stroke-width="1"/>
    <line x1="982" y1="404" x2="1010" y2="404" stroke="#0891b2" stroke-width="1"/>

    <rect x="1040" y="360" width="58" height="82" fill="none" stroke="#d4a017" stroke-width="1.5" rx="3"/>
