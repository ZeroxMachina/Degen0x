  <circle cx="1060" cy="510" r="44" fill="none" stroke="#d4a017" stroke-width="1.5" opacity="0.22"/>
  <circle cx="1090" cy="180" r="34" fill="none" stroke="#1e3a8a" stroke-width="1" opacity="0.18"/>

